# ===========================================
# SPW — Production docker-compose env template
# ===========================================
# Copy to .env.production and fill in every value before running:
#   docker compose -f docker-compose.prod.yml --env-file .env.production up -d
#
# Values below with `:?` in docker-compose.prod.yml are REQUIRED —
# compose will refuse to start if they're missing or empty.

# ---------- URLs ----------
# Public URL the dashboard is reachable at (used for CORS + NextAuth).
DASHBOARD_URL=https://dashboard.example.com
# Public URL the API is reachable at — baked into the dashboard client bundle
# at build time, so it MUST match what the browser will actually hit.
PUBLIC_API_URL=https://api.example.com
# Used by the API for CORS origin allowlist + email verification links.
API_URL=https://api.example.com

# Which host the containers bind on. `127.0.0.1:3000` means only the host
# machine can reach it — put a reverse proxy (nginx/Caddy) in front. Use
# `0.0.0.0:3000` only if this is the only service on the box and you're
# fronting it with firewall rules instead.
DASHBOARD_BIND=127.0.0.1:3000
WIDGET_BIND=127.0.0.1:8080

# ---------- Database ----------
MYSQL_ROOT_PASSWORD=change-me-strong-root-password
MYSQL_DATABASE=spw_v2_prod
MYSQL_USER=spw_app
MYSQL_PASSWORD=change-me-strong-app-password

# ---------- Redis ----------
# Optional — leave empty to run Redis without auth (fine inside the compose
# network; required for production multi-host). If set, used by api + redis.
REDIS_PASSWORD=

# ---------- Secrets ----------
# Generate each with:  openssl rand -base64 48
# JWT_SECRET / JWT_REFRESH_SECRET must be >= 32 chars or the API refuses to boot.
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# EXACTLY 32 chars — AES-256 key for at-rest secret encryption.
# Rotating this key requires re-encrypting all enc:v1: rows; plan the
# migration before you change it.
ENCRYPTION_KEY=

# NextAuth session cookie signing — generate with openssl rand -base64 48.
NEXTAUTH_SECRET=

# ---------- System SMTP ----------
# Leave SMTP_HOST empty to run in log-only mode (verification links appear
# in api logs, no real email is sent). Fine for staging; set for prod.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false
SMTP_FROM=
SMTP_FROM_NAME=

# ---------- Operator DKIM (system mail) ----------
# If set, SystemMailerService signs outbound verification / password-reset
# mail with this keypair. Separate from per-tenant DKIM on
# tenant_email_domains, which signs tenant campaign mail.
#
# Recipe: publish a DKIM TXT record at <selector>._domainkey.<domain> with
# `v=DKIM1; k=rsa; p=<base64-public-key>`, then put the matching private
# key here. Use "\n" as a single-line escape so it fits on one env value.
# Leaving these empty = unsigned system mail (current behavior).
MAIL_DKIM_DOMAIN=
MAIL_DKIM_SELECTOR=
MAIL_DKIM_PRIVATE_KEY=

# ---------- Paddle (inbound webhook) ----------
# Copy from the Paddle dashboard under Developer tools → Notifications → your
# webhook endpoint → "Secret key". Used to verify HMAC-SHA256 signatures on
# every incoming event. Leave empty to disable Paddle webhook acceptance.
PADDLE_WEBHOOK_SECRET=
# Days a tenant stays in 'grace' after a failed payment before we flip them
# to 'expired'. Default 7. During grace the widget keeps serving so a retry
# or card-update can recover without an outage.
PADDLE_GRACE_DAYS=7

# ---------- Paddle (outbound checkout, 6E) ----------
# API key from Paddle's dashboard → Developer tools → Authentication. Used
# server-side to create checkout transactions with tenant context attached
# as custom_data. Leave empty to disable the /api/billing/checkout endpoint
# (returns 503). Boot-audit rejects placeholder values in prod.
PADDLE_API_KEY=
# Base URL for Paddle Billing API. Use https://sandbox-api.paddle.com for
# sandbox accounts, https://api.paddle.com for live.
PADDLE_API_URL=https://api.paddle.com
