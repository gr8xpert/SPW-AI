# =========================================================================
# SPW v2 — Production environment file
# =========================================================================
# Copy to `.env.production` at the repo root and fill in every value.
# This file is read by `docker compose -f docker-compose.prod.yml up -d`.
# The compose file refuses to start if any of the `?:required` keys is
# missing — there are no silent fallbacks in production.
#
# For the bare-metal / PM2 deploy path (the current spw-ai.com setup),
# use `apps/api/.env.production.template` and `apps/dashboard/.env.production.template`
# instead — those go straight into the per-app .env files on the server.
# =========================================================================

# ---------- Public URLs (must match your DNS + nginx config) -------------
API_URL=https://api.spw-ai.com
DASHBOARD_URL=https://dashboard.spw-ai.com
# Baked into the dashboard client bundle at build time; cannot be changed
# without rebuilding the dashboard image.
PUBLIC_API_URL=https://api.spw-ai.com

# ---------- MySQL ---------------------------------------------------------
MYSQL_ROOT_PASSWORD=change-me-strong
MYSQL_DATABASE=spw_v2
MYSQL_USER=spw_user
MYSQL_PASSWORD=change-me-strong

# ---------- Redis ---------------------------------------------------------
# Leave empty for an unauthenticated Redis (compose still binds it to the
# internal network only). Set a password if Redis is exposed.
REDIS_PASSWORD=

# ---------- Secrets — must each be a fresh random string ----------------
# Generate with: openssl rand -base64 32 | head -c 48
JWT_SECRET=change-me-at-least-32-chars
JWT_REFRESH_SECRET=change-me-also-at-least-32-chars
# Generate with: openssl rand -base64 24 | head -c 32  (exactly 32 chars)
ENCRYPTION_KEY=change-me-exactly-32-chars-long!!
NEXTAUTH_SECRET=change-me-at-least-32-chars

# ---------- Optional: JWT lifetimes (defaults shown) ---------------------
# JWT_EXPIRES_IN=7d
# JWT_REFRESH_EXPIRES_IN=30d

# ---------- System SMTP (for invite emails, ticket notifications) -------
# Leave SMTP_* blank to disable outbound system mail. Boot-audit rejects
# partial/placeholder values in production.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false
SMTP_FROM=
SMTP_FROM_NAME=

# Optional operator DKIM (signs system mail). Empty = unsigned.
MAIL_DKIM_DOMAIN=
MAIL_DKIM_SELECTOR=
MAIL_DKIM_PRIVATE_KEY=

# ---------- Stripe (plan subscriptions + credit hours) -------------------
# Leave blank to disable checkout. Boot-audit rejects placeholder values
# in production.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=
# Grace period (days) after expiry before the widget stops responding.
STRIPE_GRACE_DAYS=7

# ---------- Seed user (one-time) -----------------------------------------
# Set BOTH values to seed an initial super-admin via
# `docker compose -f docker-compose.prod.yml exec api node dist/database/seed.js`.
SEED_SUPER_ADMIN_EMAIL=
SEED_SUPER_ADMIN_PASSWORD=

# ---------- Bind addresses (only edit if not fronting with nginx) -------
# Defaults bind on 127.0.0.1 so a reverse proxy can route TLS to them.
# API_BIND=127.0.0.1:3001
# DASHBOARD_BIND=127.0.0.1:3000
# WIDGET_BIND=127.0.0.1:8080

# ---------- Image tag (rolling deploys) ----------------------------------
# IMAGE_TAG=2026.05.13
