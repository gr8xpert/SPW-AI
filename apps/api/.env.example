# ===========================================
# SPW API - Environment Configuration
# ===========================================

# Application
NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001
DASHBOARD_URL=http://localhost:3000

# Database
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_NAME=spw_v2_dev
DATABASE_USER=root
DATABASE_PASSWORD=password
DATABASE_LOGGING=true
DATABASE_SYNCHRONIZE=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Authentication
# Both secrets are REQUIRED. App refuses to start if either is missing or < 32 chars.
# Generate each with: openssl rand -base64 48
JWT_SECRET=
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=30d

# Encryption (for sensitive data in DB)
ENCRYPTION_KEY=32-character-encryption-key-here

# System SMTP (platform emails — verification, password reset).
# When SMTP_HOST is empty, outgoing messages are logged instead of sent.
# SMTP_FROM is required once SMTP_HOST is set.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false
SMTP_FROM=
SMTP_FROM_NAME=
